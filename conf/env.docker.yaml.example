# Docker 環境配置文件範例
# 複製此文件為 env.docker.yaml 並填入真實配置
# cp conf/env.docker.yaml.example conf/env.docker.yaml

APP_Mode: debug  # debug | release | test
Port: 5001
JwtSecret: your_jwt_secret_here_at_least_32_characters_long
IsEventBroker : true  # 是否啟用事件驅動


Mysql:
  IsEnable: true
  host: mysql  # Docker Compose 服務名稱
  port: 3306
  userName: root
  password: your_mysql_password
  dbName: your_database_name

MongoDB:
  IsEnable: false
  host: mongodb  # Docker Compose 服務名稱
  port: 27017
  userName: root
  password: your_mongodb_password
  dbName: mongoDBName

Redis:
  IsEnable: true
  host: redis  # Docker Compose 服務名稱
  port: 6379
  password: your_redis_password
