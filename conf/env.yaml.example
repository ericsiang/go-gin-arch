# 配置文件範例
# 複製此文件為 env.yaml 並填入真實配置
# cp conf/env.yaml.example conf/env.yaml

APP_Mode: debug  # debug | release | test
Port: 5001
JwtSecret: your_jwt_secret_here_at_least_32_characters_long
IsEventBroker : true  # 是否啟用事件驅動


Mysql:
  IsEnable: true
  host: localhost
  port: 3306
  userName: your_mysql_user
  password: your_mysql_password
  dbName: your_database_name

MongoDB:
  IsEnable: false
  host: localhost
  port: 27017
  userName: your_mongodb_user
  password: your_mongodb_password
  dbName: mongoDBName

Redis:
  IsEnable: true
  host: localhost
  port: 6379
  password: your_redis_password
